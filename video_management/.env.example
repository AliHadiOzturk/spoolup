# Video Management System Configuration
# Copy this file to .env and fill in your values

# Application
SECRET_KEY=change-this-to-a-secure-random-string
DEBUG=false

# Database (auto-created in data/ folder)
DATABASE_URL=sqlite:///data/vms.db

# Moonraker (3D Printer)
MOONRAKER_URL=http://your-printer-ip:4409
MOONRAKER_API_KEY=

# YouTube Data API v3
# Path to your OAuth client secrets JSON file
YOUTUBE_CLIENT_SECRETS=/path/to/client_secrets.json
YOUTUBE_TOKEN_FILE=data/youtube_token.json

# TikTok Content Posting API
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret

# Video Processing
FFMPEG_PATH=ffmpeg
MAX_VIDEO_DURATION=60
OUTPUT_RESOLUTION=1080x1920

# Server
HOST=0.0.0.0
PORT=8000

# Analytics Sync (Midnight)
ANALYTICS_SYNC_HOUR=0
ANALYTICS_SYNC_MINUTE=0

# Security Settings
# IMPORTANT: For public servers, keep ALLOW_REGISTRATION=false
# Only set to true temporarily for initial setup or if you want open registration
ALLOW_REGISTRATION=false

# Admin user auto-creation (recommended for first setup)
# Set both to create admin on startup
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password

# Login rate limiting (failed attempts within 15 minutes)
MAX_LOGIN_ATTEMPTS=5